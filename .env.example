DJANGO_SECRET_KEY=django-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# SQLite for local development
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# PostgreSQL example
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=hackathon
# DB_USER=hackathon
# DB_PASSWORD=hackathon
# DB_HOST=localhost
# DB_PORT=5432

# Celery (расписание / напоминания): Redis как брокер
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# 1 = выполнять задачи синхронно (тесты без Redis)
# CELERY_TASK_ALWAYS_EAGER=0

# Тот же токен, что у бота — для sendMessage из Celery
BOT_TOKEN=
BACKEND_API_URL=
MINI_APP_URL=
# Создание хакатонов: через запятую числовые Telegram ID для первичного доступа (bootstrap).
# ORGANIZER_BOOTSTRAP_TELEGRAM_IDS=123456789,987654321

# Локально Mini App как file://: откройте mini_app/index.html?api_base=http://127.0.0.1:8000&telegram_id=ВАШ_ID
# Прод: CORS при DJANGO_DEBUG=0 — задайте список через DJANGO_CORS_ALLOWED_ORIGINS=https://example.com
# DJANGO_CORS_ALLOWED_ORIGINS=

PROXY_URL=

# OPTIONAL
LOG_LEVEL=INFO
REQUEST_TIMEOUT=10
